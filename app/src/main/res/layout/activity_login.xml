<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/imagen2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingVertical="48dp">

        <!-- Marca / titulares editoriales -->
        <TextView
            android:id="@+id/brandTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.18"
            android:text="@string/brand_title"
            android:textColor="@color/ivory_soft"
            android:textSize="26sp" />

        <TextView
            android:id="@+id/brandSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:letterSpacing="0.12"
            android:text="@string/brand_subtitle"
            android:textColor="@color/satin_red"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/loginHeadline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="20dp"
            android:letterSpacing="0.06"
            android:text="@string/login_headline"
            android:textColor="@color/ivory_soft"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Campo 1: correo electrónico -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/emailInputLayout"
            style="@style/Widget.AtelierAI.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_email">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/emailEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:textColor="@color/ivory_soft"
                android:textColorHint="#66FDFBF7" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo 2: contraseña, con ícono de ojo integrado (endIconMode=password_toggle) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/passwordInputLayout"
            style="@style/Widget.AtelierAI.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="@string/label_password"
            app:endIconMode="password_toggle"
            app:endIconContentDescription="@string/cd_toggle_password_visibility">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/passwordEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:maxLines="1"
                android:textColor="@color/ivory_soft"
                android:textColorHint="#66FDFBF7" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo 3: botón de acción, sólido, bordes rectos -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="40dp"
            android:enabled="false"
            android:text="@string/button_login" />

    </LinearLayout>

</ScrollView>
